#!/bin/bash

# Logging Setup 
LOGFILE="./pg_db_creation.log"
echo "=== PostgreSQL Database Creation Log ===" >> "$LOGFILE"
echo "Started at $(date)" >> "$LOGFILE"

# User Input
read -p "Enter PostgreSQL username: " PGUSER
read -sp "Enter password for $PGUSER: " PGPASS
read -p "Enter the name of the database to create: " DBNAME

# Export password so psql can use it non-interactively
export PGPASSWORD="$PGPASS"


echo "Database '$DBNAME': Proceeding to create" | tee -a "$LOGFILE"




# Create the Database
echo "Creating database '$DBNAME'..." | tee -a "$LOGFILE"
psql -U "$PGUSER" -c "CREATE DATABASE $DBNAME;" 2>> "$LOGFILE"

if [ $? -eq 0 ]; then
    echo "Database '$DBNAME' created successfully!" | tee -a "$LOGFILE"
else
    echo "Failed to create database '$DBNAME'. Check log." | tee -a "$LOGFILE"
fi

sudo -u postgres psql <<EOF



-- conencting to database
/c $DBNAME;

-- grant privilages
GRANT CONNECT, USAGE ON DATABASE $DBNAME TO $PGUSER;
GRANT SELECT, INSERT, DELETE, UPDATE ON ALL TABLES IN SCHEMA public TO $PGUSER;
EOF

# Final Log Entry
echo "Script finished at $(date)" >> "$LOGFILE"
